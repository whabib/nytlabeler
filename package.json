{
  "name": "nytlabeler",
  "version": "1.0.0",
  "description": "Automated Bluesky labeler for NY Times articles with monitoring dashboard",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "start": "tsx src/main.ts",
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "publish-definitions": "tsx src/publish-definitions.ts",
    "setup-labeler": "npx @skyware/labeler setup"
  },
  "dependencies": {
    "@atproto/api": "^0.13.11",
    "@skyware/jetstream": "^0.1.1",
    "@skyware/labeler": "^0.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "@types/ws": "^8.5.10",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2"
  }
}
