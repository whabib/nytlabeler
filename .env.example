# Environment Selector: 'development' or 'production'
ENV=development

# ATProto Credentials
BSKY_DID=did:plc:your-did
BSKY_SIGNING_KEY=your-signing-key
BSKY_IDENTIFIER=your-account@bsky.social
BSKY_PASSWORD=your-app-password

# PostgreSQL Database Configuration
# Local database defaults:
DB_HOST=localhost
DB_PORT=5432
DB_USER=nytdata
DB_PASSWORD=
DB_NAME=nytdata

# Production DB (for Google Cloud Run, set DB_HOST to VPC IP 10.73.128.3 or Unix socket path)
# DB_HOST=10.73.128.3
# DB_PORT=5432
# DB_USER=nytdata
# DB_PASSWORD=your_production_password
# DB_NAME=nytdata

# Server Port
PORT=4100

# Jetstream Firehose Configuration
FIREHOSE_URL=wss://jetstream.atproto.tools/subscribe
WANTED_COLLECTION=app.bsky.feed.post

# Dry Run Mode: Parse firehose and local queries, but do NOT push labels or service records to the live network (set to true/false)
DRY_RUN=true
