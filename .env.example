# Environment Selector: 'development' or 'production'
ENV=development

# ATProto Credentials
BSKY_DID=did:plc:your-did
BSKY_SIGNING_KEY=your-signing-key
BSKY_IDENTIFIER=your-account.bsky.social
BSKY_PASSWORD=your-app-password

# PostgreSQL Database Configuration
# Local database connection string:
DATABASE_URL=postgresql://nytdata@localhost:5432/nytdata

# Production DB Connection String (typically loaded via Google Secret Manager in Cloud Run)
# DATABASE_URL=postgresql://nytdata:your_production_password@10.73.128.3:5432/nytdata

# Server Port
PORT=4100

# Jetstream Firehose Configuration
FIREHOSE_URL=wss://jetstream1.us-east.bsky.network/subscribe
WANTED_COLLECTION=app.bsky.feed.post

# Dry Run Mode: Parse firehose and local queries, but do NOT push labels or service records to the live network (set to true/false)
DRY_RUN=true
