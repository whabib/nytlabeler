# Environment Selector: 'development' or 'production'
ENV=development

# ATProto Credentials (Development)
DEV_DID=did:plc:xxx
DEV_SIGNING_KEY=xxx
DEV_BSKY_IDENTIFIER=nyt-labeler-dev@bsky.social
DEV_BSKY_PASSWORD=xxx

# ATProto Credentials (Production)
PROD_DID=did:plc:xxx
PROD_SIGNING_KEY=xxx
PROD_BSKY_IDENTIFIER=nyt-labeler@bsky.social
PROD_BSKY_PASSWORD=xxx

# PostgreSQL Database Configuration
# Local database defaults:
DB_HOST=localhost
DB_PORT=5432
DB_USER=nytdata
DB_PASSWORD=
DB_NAME=nytdata

# Production DB (for Google Cloud Run, set DB_HOST to VPC IP 10.73.128.3 or Unix socket path)
# DB_HOST=10.73.128.3
# DB_PORT=5432
# DB_USER=nytdata
# DB_PASSWORD=your_production_password
# DB_NAME=nytdata

# Server Port
PORT=4100

# Jetstream Firehose Configuration
FIREHOSE_URL=wss://jetstream.atproto.tools/subscribe
WANTED_COLLECTION=app.bsky.feed.post

# Dry Run Mode: Parse firehose and local queries, but do NOT push labels or service records to the live network (set to true/false)
DRY_RUN=true
